{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$version": "1.0",
  "$description": "Gensyn Design typography tokens — July 2026",

  "font": {
    "family": {
      "display": {
        "$value": "'Noto Sans', 'Segoe UI', system-ui, sans-serif",
        "$type": "fontFamily",
        "$description": "Display and headline font. Substitutes Segoe UI Bold (proprietary, unlicensed for web) — confirmed final."
      },
      "body-web": {
        "$value": "'Enriqueta', Georgia, serif",
        "$type": "fontFamily",
        "$description": "Web body font — real brand font, no substitution."
      },
      "body-print": {
        "$value": "'Lora', 'Californian FB', Georgia, serif",
        "$type": "fontFamily",
        "$description": "Print body font. Substitutes Californian FB (proprietary) — confirmed final."
      }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium":  { "$value": 500, "$type": "fontWeight" },
      "bold":    { "$value": 700, "$type": "fontWeight" },
      "display": { "$value": 800, "$type": "fontWeight" }
    },
    "size": {
      "xs":   { "$value": "13px", "$type": "dimension" },
      "sm":   { "$value": "15px", "$type": "dimension" },
      "base": { "$value": "17px", "$type": "dimension" },
      "md":   { "$value": "20px", "$type": "dimension" },
      "lg":   { "$value": "24px", "$type": "dimension" },
      "xl":   { "$value": "32px", "$type": "dimension" },
      "2xl":  { "$value": "42px", "$type": "dimension" },
      "3xl":  { "$value": "56px", "$type": "dimension" },
      "4xl":  { "$value": "72px", "$type": "dimension" }
    },
    "lineHeight": {
      "tight":   { "$value": 1.1,  "$type": "number" },
      "snug":    { "$value": 1.3,  "$type": "number" },
      "normal":  { "$value": 1.55, "$type": "number" },
      "relaxed": { "$value": 1.7,  "$type": "number" }
    },
    "letterSpacing": {
      "tight":  { "$value": "-0.01em", "$type": "dimension" },
      "normal": { "$value": "0",       "$type": "dimension" },
      "wide":   { "$value": "0.06em",  "$type": "dimension" }
    }
  }
}
